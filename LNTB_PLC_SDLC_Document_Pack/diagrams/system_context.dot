digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.25, nodesep=0.55, ranksep=0.8, fontname="Arial"];
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11, color="#1F4E78", fillcolor="#EAF2F8", penwidth=1.2, margin="0.15,0.08"];
  edge [fontname="Arial", fontsize=9, color="#4F6D7A", arrowsize=0.8];

  farmer [label="Farmer\nKhmer Mobile App", fillcolor="#E8F5E9", color="#2E7D32"];
  esp32 [label="ESP32 Sensor Node\nMoisture · Temp/Humidity · Light\nFlow · Energy · Pump/Fan/Servo", fillcolor="#FFF8E1", color="#F9A825"];
  camera [label="ESP32-CAM\nTomato Images", fillcolor="#FFF8E1", color="#F9A825"];
  backend [label="Laravel 13 Backend\nREST API · Rules · Cost · Notifications\nReverb · Scheduler · Audit", fillcolor="#E3F2FD", color="#1565C0"];
  db [shape=cylinder, label="MySQL Database\nOperational + Historical Data", fillcolor="#F3E5F5", color="#6A1B9A"];
  storage [shape=folder, label="Private Image Storage\nPilot local / S3-compatible", fillcolor="#F3E5F5", color="#6A1B9A"];
  ai [label="AI Inference Service\nRipeness Classification", fillcolor="#FCE4EC", color="#AD1457"];
  fcm [label="Firebase Cloud Messaging\nPush Notifications", fillcolor="#E0F7FA", color="#00838F"];

  esp32 -> backend [label="HTTPS readings / command polling"];
  camera -> backend [label="HTTPS image upload"];
  backend -> esp32 [label="Commands / configuration"];
  backend -> db [label="Read / write"];
  backend -> storage [label="Store / retrieve images"];
  backend -> ai [label="Inference request"];
